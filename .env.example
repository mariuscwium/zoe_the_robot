# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_WEBHOOK_SECRET=random-secret-string

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://us1-example.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# Google Calendar (OAuth2 — per-member tokens stored in Redis)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_CALENDAR_ID=family@group.calendar.google.com
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.vercel.app/api/oauth/google/callback

# OpenAI (Whisper transcription for voice messages — optional)
OPENAI_API_KEY=sk-...

# Debug UI
DEBUG_PATH=debug-secret-slug
DEBUG_PASSWORD_HASH=$2b$10$...
DEBUG_JWT_SECRET=random-jwt-secret
